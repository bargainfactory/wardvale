# Public site URL (used in metadata + sitemap)
NEXT_PUBLIC_SITE_URL=https://flowforge.ai

# OpenAI (server-only) — powers instant-audit + chatbot
OPENAI_API_KEY=sk-...

# Stripe (server-only) — recurring retainer checkout + webhook
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Stripe price IDs for each retainer tier
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_GROWTH=price_...
STRIPE_PRICE_SCALE=price_...

# Supabase — client portal auth + automation run logs (run supabase/schema.sql)
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=ey...
SUPABASE_SERVICE_ROLE_KEY=ey...

# Resend (server-only) — transactional email (audit report). Site works without it.
RESEND_API_KEY=re_...
EMAIL_FROM="FlowForge AI <hello@flowforge.ai>"

# Upstash Redis (server-only) — durable cross-instance rate limiting.
# Falls back to in-memory limiting when unset.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Cloudflare Turnstile — bot protection on the quote/audit forms.
# When unset, forms work with no CAPTCHA. Set both to enable.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Google OAuth (server-only) — powers "See it on your data" Gmail read-only demo (/connect).
# Add https://YOURDOMAIN/api/connect/google/callback as an authorized redirect URI.
# When unset, /connect shows a sample preview instead of a live one.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# PostHog (server-only, optional) — /api/track forwards first-party events here
# in addition to Supabase. Leave blank to keep analytics purely first-party.
POSTHOG_KEY=
POSTHOG_HOST=https://us.i.posthog.com

# Calendly link used on the quote -> booking handoff
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/flowforge/discovery

# Optional: Google site verification
GOOGLE_SITE_VERIFICATION=
