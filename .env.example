# Public site URL (used in metadata + sitemap)
NEXT_PUBLIC_SITE_URL=https://flowforge.ai

# OpenAI (server-only) — powers instant-audit + chatbot
OPENAI_API_KEY=sk-...
# Model routing + resilience (all optional; see lib/model.ts). OPENAI_MODEL sets
# the shared default; OPENAI_MODEL_<PURPOSE> overrides one lane (DRAFT, TRIAGE,
# VOICE, CHAT, QUOTE, AUDIT, WORKFLOW, PREVIEW), e.g. OPENAI_MODEL_DRAFT=gpt-4o.
# OPENAI_TIMEOUT_MS caps each call; OPENAI_MAX_RETRIES bounds retries on 429/5xx.
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_TIMEOUT_MS=20000
# OPENAI_MAX_RETRIES=2

# Error/alert sink (server-only, optional; see lib/report.ts). When set, failures
# that would otherwise be swallowed are POSTed here as { text } — works with a
# Slack incoming webhook. Errors also log to the console and the error_events table.
# ERROR_WEBHOOK_URL=https://hooks.slack.com/services/...

# Trace sampling (server-only, optional; see lib/trace.ts). Fraction [0,1] of
# ORDINARY traces to persist; interesting traces (errors, injections, connector
# failures, model fallbacks) are always kept. Default 1 (keep all). Lower it as
# volume grows to bound the traces table + write cost.
# TRACE_SAMPLE_RATE=1

# LLM-as-judge (server-only, optional; see lib/judge.ts + /api/cron/judge). The
# judge cron runs cheap deterministic checks on all recent decisions and the
# expensive LLM rubric on JUDGE_SAMPLE_RATE of them. Lower the rate to cut token
# cost at scale; tune the model per lane with OPENAI_MODEL_JUDGE.
# JUDGE_SAMPLE_RATE=1
# JUDGE_MAX_PER_RUN=100
# JUDGE_CONCURRENCY=4

# Stripe (server-only) — recurring retainer checkout + webhook
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Stripe price IDs for each retainer tier
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_GROWTH=price_...
STRIPE_PRICE_SCALE=price_...
# Growth price A/B test — variant B ($2,500) uses this second Stripe price.
# Leave blank to serve every visitor variant A ($2,000).
STRIPE_PRICE_GROWTH_B=price_...

# Supabase — client portal auth + automation run logs (run supabase/schema.sql)
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=ey...
SUPABASE_SERVICE_ROLE_KEY=ey...

# Token encryption key (server-only) — envelope-encrypts stored OAuth tokens +
# API keys at rest (AES-256-GCM), so a DB dump alone can't read client creds.
# Generate: `openssl rand -base64 32`. If unset, tokens are stored plaintext
# (dev only). Rotating this key makes existing encrypted tokens unreadable —
# clients would need to reconnect; keep it stable + backed up.
TOKEN_ENC_KEY=

# Resend (server-only) — transactional email (audit report). Site works without it.
RESEND_API_KEY=re_...
EMAIL_FROM="FlowForge AI <hello@flowforge.ai>"

# Upstash Redis (server-only) — durable cross-instance rate limiting.
# Falls back to in-memory limiting when unset.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Cloudflare Turnstile — bot protection on the quote/audit forms.
# When unset, forms work with no CAPTCHA. Set both to enable.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Google OAuth (server-only) — powers "See it on your data" Gmail read-only demo (/connect).
# Add https://YOURDOMAIN/api/connect/google/callback as an authorized redirect URI.
# When unset, /connect shows a sample preview instead of a live one.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Connectors (server-only) — OAuth apps for the /connections directory. Each
# provider becomes "Ready" once its id + secret are set; redirect URI is
# https://YOURDOMAIN/api/connect/<provider>/callback. Leave blank to keep it
# "Setup needed". Google (above) also powers the Google Workspace connector.
QUICKBOOKS_CLIENT_ID=
QUICKBOOKS_CLIENT_SECRET=
# QuickBooks API environment for live invoice pulls: "sandbox" (default) or "production".
QUICKBOOKS_ENV=sandbox
XERO_CLIENT_ID=
XERO_CLIENT_SECRET=
# Workday OAuth is tenant-specific — set the tenant's authorize/token URLs too.
WORKDAY_CLIENT_ID=
WORKDAY_CLIENT_SECRET=
WORKDAY_AUTH_URL=
WORKDAY_TOKEN_URL=
# Workday is tenant-specific: base API host and a default RaaS report URL (JSON).
# Per-connection report URLs override this (stored as the connection's external id).
WORKDAY_API_URL=
WORKDAY_REPORT_URL=
HUBSPOT_CLIENT_ID=
HUBSPOT_CLIENT_SECRET=
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
CALENDLY_CLIENT_ID=
CALENDLY_CLIENT_SECRET=
# Microsoft 365 (Outlook mail/calendar + Teams). Azure AD app, multi-tenant.
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
# Salesforce connected app.
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
# Meta (WhatsApp Business, Instagram DMs, Messenger) — Facebook Login app.
META_CLIENT_ID=
META_CLIENT_SECRET=
# Shopify — per-shop OAuth. Set SHOPIFY_SHOP to the store domain (acme.myshopify.com).
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=
SHOPIFY_SHOP=
# Optional: dedicated Shopify webhook signing secret. Falls back to
# SHOPIFY_CLIENT_SECRET. Register webhooks (checkouts/create, orders/create)
# pointed at NEXT_PUBLIC_SITE_URL/api/webhooks/shopify for real-time triggers.
SHOPIFY_WEBHOOK_SECRET=
# Square (POS/orders/customers).
SQUARE_CLIENT_ID=
SQUARE_CLIENT_SECRET=
# Zendesk — per-subdomain OAuth. Set ZENDESK_SUBDOMAIN (acme -> acme.zendesk.com).
ZENDESK_CLIENT_ID=
ZENDESK_CLIENT_SECRET=
ZENDESK_SUBDOMAIN=
# Gorgias — per-subdomain OAuth. Set GORGIAS_SUBDOMAIN.
GORGIAS_CLIENT_ID=
GORGIAS_CLIENT_SECRET=
GORGIAS_SUBDOMAIN=
# Intercom.
INTERCOM_CLIENT_ID=
INTERCOM_CLIENT_SECRET=
# Mailchimp.
MAILCHIMP_CLIENT_ID=
MAILCHIMP_CLIENT_SECRET=
# Klaviyo — OAuth requires PKCE (handled automatically).
KLAVIYO_CLIENT_ID=
KLAVIYO_CLIENT_SECRET=
# Gusto (SMB payroll). GUSTO_API_BASE defaults to production; use the demo host to test.
GUSTO_CLIENT_ID=
GUSTO_CLIENT_SECRET=
GUSTO_API_BASE=https://api.gusto.com
# Jobber (home-services field ops).
JOBBER_CLIENT_ID=
JOBBER_CLIENT_SECRET=
# Clio (legal practice management).
CLIO_CLIENT_ID=
CLIO_CLIENT_SECRET=
# DocuSign — DOCUSIGN_AUTH_BASE defaults to the demo host (account-d.docusign.com);
# set it to https://account.docusign.com for production.
DOCUSIGN_CLIENT_ID=
DOCUSIGN_CLIENT_SECRET=
DOCUSIGN_AUTH_BASE=https://account-d.docusign.com
# Google Business Profile reuses GOOGLE_CLIENT_ID/SECRET above (business.manage scope).

# API-key connectors (Twilio, Stripe, Yelp): clients paste their own key in the
# portal — no platform-level app needed. TWILIO_AUTH_TOKEN below is only for
# validating inbound webhook signatures at the agency level (optional).
TWILIO_AUTH_TOKEN=
# Optional: the exact public URL Twilio calls, if it differs from
# NEXT_PUBLIC_SITE_URL/api/webhooks/twilio (e.g. behind a proxy). Used for
# webhook signature validation.
TWILIO_WEBHOOK_URL=
# Optional base (scheme+host) for Twilio Voice webhook signature validation when
# behind a proxy; defaults to NEXT_PUBLIC_SITE_URL. Point your Twilio number's
# Voice webhook at NEXT_PUBLIC_SITE_URL/api/webhooks/twilio/voice.
TWILIO_WEBHOOK_URL_BASE=

# PostHog (server-only, optional) — /api/track forwards first-party events here
# in addition to Supabase. Leave blank to keep analytics purely first-party.
POSTHOG_KEY=
POSTHOG_HOST=https://us.i.posthog.com

# Admin token (server-only) — gates /api/admin/traces (agent decision tracing
# export for debugging + building golden eval sets). Leave blank to disable.
ADMIN_TOKEN=

# Cron secret (server-only) — authenticates /api/cron/* (autonomous agent
# scheduler + daily digest). Set the same value in the Vercel Cron config.
# Leave blank to disable the scheduler entirely.
CRON_SECRET=
# Scheduler dispatch (server-only, optional; see lib/scheduler.ts). With QSTASH_TOKEN
# set, each due agent is published to Upstash QStash for durable delivery with retry
# + dead-letter; without it, the cron runs jobs in-process with bounded concurrency.
# QSTASH_TOKEN=
# QSTASH_RETRIES=3
# SCHEDULER_CONCURRENCY=6
# SCHEDULER_MAX_INLINE=100

# Calendly link used on the quote -> booking handoff
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/flowforge/discovery

# Optional: Google site verification
GOOGLE_SITE_VERIFICATION=
